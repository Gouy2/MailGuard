# LLM API 配置
OPENAI_API_KEY=sk-xxx
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# Server 配置
# 设置后，除 /health 外的 API 都需要 Authorization: Bearer <token>
# MAILGUARD_AUTH_TOKEN=your-secret-token

# 默认关闭开发工具。设置为 1 后注册 list_files/read_text_file/run_shell_command。
# MAILGUARD_DEV_TOOLS=1

# 可选 SQLite 状态持久化。相对路径以 server/ 为基准。
# MAILGUARD_STATE_DB=data/mailguard_state.db

# 邮件 provider。支持 mock 或 qq-imap。
# MAILGUARD_EMAIL_PROVIDER=mock

# QQ / Foxmail IMAP provider
# 个人 QQ/Foxmail 邮箱需要先在网页版开启 IMAP/SMTP，并使用授权码而不是登录密码。
# MAILGUARD_EMAIL_PROVIDER=qq-imap
# MAILGUARD_QQ_EMAIL=your_account@foxmail.com
# MAILGUARD_QQ_AUTH_CODE=your-qq-mail-auth-code
# MAILGUARD_QQ_IMAP_HOST=imap.qq.com
# MAILGUARD_QQ_IMAP_PORT=993
# MAILGUARD_QQ_IMAP_MAILBOX=INBOX
# MAILGUARD_QQ_ARCHIVE_MAILBOX=Archive
# MAILGUARD_QQ_DRAFTS_MAILBOX=Drafts
