# LLM API 配置
OPENAI_API_KEY=sk-xxx
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# Server 配置
# 设置后，除 /health 外的 API 都需要 Authorization: Bearer <token>
# WISPERA_AUTH_TOKEN=your-secret-token

# 默认关闭开发工具。设置为 1 后注册 list_files/read_text_file/run_shell_command。
# WISPERA_DEV_TOOLS=1

# 可选 SQLite 状态持久化。相对路径以 server/ 为基准。
# WISPERA_STATE_DB=data/wispera_state.db

# 邮件 provider。当前仅支持 mock，后续会加入 outlook-readonly。
# WISPERA_EMAIL_PROVIDER=mock
